# 服务端口
PORT=3000

# 工作区文件服务根目录（/workspace/* 接口使用）
WORKSPACE_DIR=/path/to/your/workspace

# 数据库连接（Neon PostgreSQL）
DATABASE_URL=postgresql://username:password@host.neon.tech/neondb?sslmode=require

# 环境标识
NODE_ENV=development

# OpenAI 配置
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# 显式开启思考模式（可选）：DeepSeek V4 Pro 等新版思考模型需要设为 true
# DeepSeek R1 自动输出思考内容，无需设置；普通模型留空
OPENAI_THINKING_ENABLED=
# 推理强度（可选）：OpenAI o1/o3/o4 及 DeepSeek V4 Pro 支持（low / medium / high）
OPENAI_REASONING_EFFORT=
# 是否启用搜索工具（Tavily MCP）：默认开启，设为 false 则全局禁用
SEARCH_ENABLED=

# LangGraph 代理配置
LANGGRAPH_API_URL=http://localhost:2024
ASSISTANT_ID=base_agent

# LangSmith API 密钥才能连接本地代理
# https://smith.langchain.com/o/xxxxxx/settings/apikeys
LANGSMITH_API_KEY=xxxxx
# 如果您不希望数据被追踪到 LangSmith，请LANGSMITH_TRACING=false在应用程序.env文件中进行设置。
# 禁用追踪后，任何数据都不会离开您的本地服务器。
LANGSMITH_TRACING=false